{
  "name": "obsidian-capture-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r --parallel run build",
    "test": "pnpm -r --parallel run test",
    "test:unit": "pnpm -r --parallel run test:unit",
    "test:e2e": "pnpm --filter @obsidian-capture/app run test:e2e",
    "test:ui": "pnpm --filter @obsidian-capture/app run test:ui",
    "typecheck": "pnpm -r --parallel run typecheck",
    "format": "prettier --write .",
    "deploy:app": "pnpm --filter @obsidian-capture/app run deploy",
    "deploy:scraper": "pnpm --filter @obsidian-capture/scraper run deploy",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "latest"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "packageManager": "pnpm@10.31.0",
  "volta": {
    "node": "24.14.0"
  }
}
