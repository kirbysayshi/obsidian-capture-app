    "test:ui":   "playwright test --ui",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mozilla/readability": "0.6.0"
  },
  "devDependencies": {
    "vite": "7.3.1",
    "gh-pages": "6.3.0",
    "@playwright/test": "1.50.1",
    "typescript": "5.8.3"
  },
  "packageManager": "pnpm@10.31.0"
}
