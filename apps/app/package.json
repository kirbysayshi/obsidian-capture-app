{
  "name": "@obsidian-capture/app",
  "version": "1.0.0",
  "description": "Capture web content and notes into Obsidian",
  "scripts": {
    "dev":       "vite",
    "build":     "vite build",
    "preview":   "vite preview",
    "deploy":    "pnpm build && gh-pages -d dist",
