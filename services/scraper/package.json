{
  "name": "@obsidian-capture/scraper",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "tsx --test src/index.test.ts",
    "typecheck": "tsc --noEmit",
    "deploy": "pnpm build && pnpm --filter=@obsidian-capture/scraper deploy --legacy .deploy && cd .deploy && fly deploy"
  },
  "dependencies": {
    "@hono/node-server": "1.19.11",
    "dotenv": "^17.3.1",
    "hono": "4.12.5",
    "undici": "7.22.0"
  },
  "devDependencies": {
    "@types/node": "22.15.21",
    "tsx": "4.19.4",
    "typescript": "5.8.3"
  }
}
